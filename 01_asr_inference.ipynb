# Cell 1: Setup and Imports
import torch
import librosa
import numpy as np
import pandas as pd
from jiwer import wer, cer
from transformers import AutoProcessor, AutoModelForSpeechSeq2Seq
import warnings
warnings.filterwarnings('ignore')

print(" Imports loaded")
print(f"CUDA available: {torch.cuda.is_available()}")

# Cell 2: Load Models
models = {
    'whisper_hausa': 'mosesdaudu/whisper-large-hausa',
    'hausa_asr': 'NCAIR1/Hausa-ASR',
}

loaded_models = {}
for name, model_id in models.items():
    print(f"Loading {name}...")
    processor = AutoProcessor.from_pretrained(model_id)
    model = AutoModelForSpeechSeq2Seq.from_pretrained(model_id)
    if torch.cuda.is_available():
        model = model.to('cuda')
        model = model.half()
    model.eval()
    loaded_models[name] = (model, processor)
    print(f" {name} loaded")

# Cell 3: Load Sample Data
import pandas as pd
references_df = pd.read_csv('../data/transcriptions/references.csv')
print(f"Loaded {len(references_df)} samples")
print(references_df.head())

# Cell 4: Transcribe Function
def transcribe_audio(audio_path, model, processor):
    # Load audio
    audio, sr = librosa.load(audio_path, sr=16000)
    
    # Process
    inputs = processor(audio, sampling_rate=16000, 
                      return_tensors="pt").to(model.device)
    
    # Generate
    with torch.no_grad():
        generated = model.generate(inputs.input_features)
    
    # Decode
    transcription = processor.batch_decode(generated, 
                                          skip_special_tokens=True)[0]
    return transcription

# Cell 5: Run Inference and Compute Metrics
results = []
for idx, row in references_df.iterrows():
    audio_path = f"../data/sample_audio/{row['audio_file']}"
    
    for model_name, (model, processor) in loaded_models.items():
        pred = transcribe_audio(audio_path, model, processor)
        wer_score = wer(row['reference'], pred)
        cer_score = cer(row['reference'], pred)
        
        results.append({
            'model': model_name,
            'reference': row['reference'],
            'prediction': pred,
            'wer': wer_score,
            'cer': cer_score
        })

# Display results
results_df = pd.DataFrame(results)
print(results_df.groupby('model')[['wer', 'cer']].mean())
